/* ========================================
   ISLAMIC MODERN UPDATE - CSS RECOMMENDATIONS
   Ready-to-Use Color Palette & Styles
   ======================================== */

:root {
  /* ========== UPDATED COLOR PALETTE - Islamic Modern ========== */
  
  /* Primary Colors - Warm, Sophisticated */
  --color-primary: #1a3a52;           /* Deep teal - sophisticated base */
  --color-primary-dark: #0f2438;      /* Darker for depth */
  --color-primary-light: #2a5a7a;     /* Lighter for hover/active states */
  
  /* Warm Accents - Islamic Heritage Feel */
  --color-accent-gold: #d4a574;       /* Warm gold - luxury, Islamic aesthetic */
  --color-accent-rust: #b85c4f;       /* Rust/terracotta - warmth, earthy */
  --color-accent-sage: #6b8e7e;       /* Sage green - nature, balance */
  
  /* Background & Text */
  --color-bg: #faf8f5;                /* Warm off-white/cream - inviting */
  --color-bg-light: #f5f2ed;          /* Slightly darker for contrast */
  --color-text: #2a2a2a;              /* Deep charcoal - readable, warm */
  --color-text-light: #5a5a5a;        /* Medium gray for secondary content */
  --color-border: #e8e5e0;            /* Warm border color */
  
  /* Gradients - Multi-color harmony */
  --gradient-gold-rust: linear-gradient(90deg, #d4a574 0%, #b85c4f 100%);
  --gradient-primary: linear-gradient(135deg, #1a3a52 0%, #0f2438 100%);
  
  /* Typography - Modern + Traditional */
  --font-serif: 'Georgia', 'Garamond', serif;
  --font-sans: 'Segoe UI', 'Roboto', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  
  /* Shadows - Warm depth */
  --shadow-sm: 0 2px 8px rgba(26, 58, 82, 0.08);
  --shadow-md: 0 4px 12px rgba(26, 58, 82, 0.1);
  --shadow-lg: 0 8px 24px rgba(26, 58, 82, 0.12);
  --shadow-xl: 0 12px 32px rgba(26, 58, 82, 0.15);
  
  /* Transitions - Smooth interactions */
  --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ========================================
   TYPOGRAPHY UPDATES
   ======================================== */

h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-serif);
  font-weight: 700;
  line-height: 1.25;
  color: var(--color-primary);
  letter-spacing: -0.03em;
}

h1 {
  font-size: 2.75rem;
  margin-bottom: 2rem;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
}

h2 {
  font-size: 2rem;
  margin-bottom: 1.5rem;
  border-bottom: 3px solid var(--color-accent-gold);
  padding-bottom: 0.5rem;
  color: var(--color-primary);
  font-weight: 700;
  transition: border-color 0.3s ease;
}

h2:hover {
  border-bottom-color: var(--color-accent-rust);
}

h3 {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 1rem;
}

p {
  font-size: 1.05rem;
  line-height: 1.8;
  margin-bottom: 1.5rem;
  color: var(--color-text);
  letter-spacing: 0.3px;
}

a {
  color: var(--color-primary);
  text-decoration: none;
  font-weight: 600;
  border-bottom: 2px solid transparent;
  transition: all 0.3s ease;
  position: relative;
}

a:hover {
  color: var(--color-accent-rust);
  border-bottom-color: var(--color-accent-gold);
}

/* ========================================
   HEADER - Bold Modern Islamic
   ======================================== */

header {
  background: var(--gradient-primary);
  color: white;
  padding: 2rem 0;
  position: relative;
  margin-bottom: 2.5rem;
  box-shadow: var(--shadow-xl);
  border-bottom: 4px solid var(--color-accent-gold);
  overflow: hidden;
}

/* Subtle diagonal pattern on header */
header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    repeating-linear-gradient(
      45deg,
      transparent,
      transparent 2px,
      rgba(212, 165, 116, 0.04) 2px,
      rgba(212, 165, 116, 0.04) 4px
    );
  pointer-events: none;
  z-index: 1;
}

header .container {
  position: relative;
  z-index: 2;
}

header .brand h1 {
  font-family: var(--font-serif);
  font-size: 2.3rem;
  margin: 0 0 0.5rem 0;
  color: white;
  font-weight: 700;
  letter-spacing: -0.05em;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
}

header .brand p {
  margin: 0;
  color: rgba(255, 255, 255, 0.9);
  font-size: 0.9rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

header nav {
  display: flex;
  gap: 2rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 1.5rem;
}

header nav a {
  color: white;
  font-weight: 500;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid transparent;
  transition: all 0.3s ease;
  position: relative;
  font-size: 0.95rem;
}

header nav a::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 3px;
  background: var(--gradient-gold-rust);
  transition: width 0.3s ease;
}

header nav a:hover {
  color: var(--color-accent-gold);
  text-decoration: none;
}

header nav a:hover::after {
  width: 100%;
}

/* ========================================
   HERO SECTION - Inviting & Dynamic
   ======================================== */

.hero {
  background: linear-gradient(135deg,
    rgba(26, 58, 82, 0.04) 0%,
    rgba(193, 124, 79, 0.04) 100%),
    white;
  
  border-radius: 16px;
  padding: 4rem 2rem;
  margin-bottom: 3rem;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-lg);
  border: 1px solid rgba(212, 165, 116, 0.1);
}

/* Subtle accent glow on right side */
.hero::before {
  content: '';
  position: absolute;
  top: -100px;
  right: -100px;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle,
    rgba(212, 165, 116, 0.08),
    transparent 70%);
  border-radius: 50%;
  z-index: 0;
  pointer-events: none;
}

.hero h1 {
  font-family: var(--font-serif);
  font-size: 2.75rem;
  color: var(--color-primary);
  margin-bottom: 1.5rem;
  z-index: 1;
  position: relative;
  line-height: 1.2;
}

.hero p {
  font-size: 1.15rem;
  color: var(--color-text-light);
  max-width: 650px;
  margin: 0 auto;
  z-index: 1;
  position: relative;
}

/* ========================================
   ARTICLE CARDS - Depth & Dynamic
   ======================================== */

.article-card {
  background: white;
  border: 1px solid var(--color-border);
  border-radius: 12px;
  padding: 2rem;
  margin-bottom: 1.5rem;
  
  /* Better shadow for depth */
  box-shadow: var(--shadow-md);
  
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

/* Top accent bar - animated on hover */
.article-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: var(--gradient-gold-rust);
  
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 2;
}

.article-card:hover {
  border-color: var(--color-accent-gold);
  box-shadow: var(--shadow-lg);
  transform: translateY(-6px);
}

.article-card:hover::before {
  transform: scaleX(1);
}

.article-card h2,
.article-card h3,
.article-card h4 {
  font-family: var(--font-serif);
  color: var(--color-primary);
  border-bottom: none;
  padding-bottom: 0;
  font-size: 1.4rem;
  font-weight: 700;
  margin-top: 0;
  transition: color 0.3s ease;
}

.article-card:hover h2,
.article-card:hover h3,
.article-card:hover h4 {
  color: var(--color-accent-rust);
}

.article-card .meta {
  font-size: 0.85rem;
  color: var(--color-text-light);
  margin-bottom: 1rem;
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.article-card .category {
  display: inline-block;
  background: linear-gradient(135deg,
    rgba(212, 165, 116, 0.15),
    rgba(193, 124, 79, 0.1));
  
  color: var(--color-primary);
  padding: 0.4rem 1rem;
  border-radius: 20px;
  font-weight: 600;
  font-size: 0.75rem;
  text-transform: capitalize;
  border-left: 3px solid var(--color-accent-gold);
  transition: all 0.3s ease;
}

.article-card .category:hover {
  background: linear-gradient(135deg,
    rgba(212, 165, 116, 0.25),
    rgba(193, 124, 79, 0.2));
  transform: translateX(4px);
}

.article-card a {
  color: var(--color-primary);
  font-weight: 700;
  border-bottom: 2px solid var(--color-accent-gold);
  transition: all 0.3s ease;
}

.article-card a:hover {
  color: var(--color-accent-rust);
  border-bottom-color: var(--color-accent-rust);
  padding-left: 4px;
}

/* ========================================
   FOOTER - Warm & Sophisticated
   ======================================== */

footer {
  background: var(--gradient-primary);
  color: white;
  padding: 3rem 0;
  margin-top: 4rem;
  border-top: 4px solid var(--color-accent-gold);
  position: relative;
  box-shadow: 0 -4px 12px rgba(26, 58, 82, 0.1) inset;
}

/* Subtle pattern on footer */
footer::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    repeating-linear-gradient(
      45deg,
      transparent,
      transparent 2px,
      rgba(212, 165, 116, 0.03) 2px,
      rgba(212, 165, 116, 0.03) 4px
    );
  pointer-events: none;
  z-index: 0;
}

footer .container {
  position: relative;
  z-index: 1;
}

footer .footer-content {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
  margin-bottom: 2rem;
}

footer .footer-section h3 {
  font-family: var(--font-serif);
  font-size: 1.1rem;
  margin-top: 0;
  margin-bottom: 1rem;
  color: var(--color-accent-gold);
  letter-spacing: -0.02em;
  font-weight: 700;
}

footer .footer-section ul {
  list-style: none;
  margin-left: 0;
}

footer .footer-section li {
  margin-bottom: 0.75rem;
}

footer .footer-section a {
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
  border-bottom-color: var(--color-accent-gold);
  transition: all 0.3s ease;
}

footer .footer-section a:hover {
  color: var(--color-accent-gold);
  text-decoration: underline;
}

footer .copyright {
  text-align: center;
  border-top: 1px solid rgba(255, 255, 255, 0.15);
  padding-top: 2rem;
  margin-top: 2rem;
  color: rgba(255, 255, 255, 0.7);
  font-size: 0.85rem;
}

/* ========================================
   BUTTONS & INTERACTIVE ELEMENTS
   ======================================== */

.btn {
  display: inline-block;
  padding: 0.75rem 1.5rem;
  background: var(--gradient-gold-rust);
  
  color: white;
  border: none;
  border-radius: 6px;
  font-weight: 600;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all 0.3s ease;
  text-decoration: none;
  
  box-shadow: 0 4px 12px rgba(212, 165, 116, 0.25);
  
  position: relative;
  overflow: hidden;
}

.btn::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: width 0.5s, height 0.5s;
  z-index: 1;
}

.btn:hover::before {
  width: 300px;
  height: 300px;
}

.btn:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(212, 165, 116, 0.35);
}

.btn:active {
  transform: translateY(-1px);
}

/* ========================================
   BLOCKQUOTE & SPECIAL ELEMENTS
   ======================================== */

blockquote {
  border-left: 4px solid var(--color-accent-gold);
  padding: 1.5rem;
  padding-left: 2rem;
  margin: 2rem 0;
  color: var(--color-text);
  font-style: italic;
  font-size: 1.1rem;
  line-height: 1.8;
  background: linear-gradient(135deg,
    rgba(212, 165, 116, 0.08) 0%,
    rgba(193, 124, 79, 0.04) 100%);
  border-radius: 8px;
  box-shadow: var(--shadow-sm);
  font-family: var(--font-serif);
}

code {
  font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
  font-size: 0.9em;
  background: linear-gradient(135deg,
    rgba(26, 58, 82, 0.08) 0%,
    rgba(212, 165, 116, 0.04) 100%);
  padding: 0.3em 0.6em;
  border-radius: 6px;
  color: var(--color-primary);
  border: 1px solid var(--color-border);
  font-weight: 600;
}

pre {
  background: var(--gradient-primary);
  border: 1px solid rgba(212, 165, 116, 0.2);
  border-radius: 12px;
  padding: 1.5rem;
  overflow-x: auto;
  margin: 1.5rem 0;
  font-size: 0.9rem;
  box-shadow: var(--shadow-lg);
  position: relative;
}

pre code {
  background: none;
  color: rgba(255, 255, 255, 0.9);
  padding: 0;
  border: none;
  font-weight: 400;
}

/* ========================================
   UTILITY CLASSES
   ======================================== */

.text-light {
  color: var(--color-text-light);
}

.mt-lg {
  margin-top: 2.5rem;
}

.mb-lg {
  margin-bottom: 2.5rem;
}

.accent-divider {
  height: 3px;
  background: var(--gradient-gold-rust);
  border-radius: 2px;
  margin: 2rem 0;
  opacity: 0.7;
}

/* ========================================
   RESPONSIVE ADJUSTMENTS
   ======================================== */

@media (max-width: 768px) {
  h1 {
    font-size: 2.2rem;
  }
  
  h2 {
    font-size: 1.5rem;
  }
  
  header .brand h1 {
    font-size: 1.8rem;
  }
  
  header nav {
    gap: 1rem;
  }
  
  .article-card {
    padding: 1.5rem;
  }
}

/* ========================================
   ANIMATIONS - Smooth & Purposeful
   ======================================== */

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(212, 165, 116, 0.7);
  }
  50% {
    box-shadow: 0 0 0 8px rgba(212, 165, 116, 0);
  }
}

.article-card {
  animation: slideInUp 0.5s ease-out;
}

/* ========================================
   ACCESSIBILITY - High Contrast
   ======================================== */

@media (prefers-reduced-motion: reduce) {
  * {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* High contrast mode support */
@media (prefers-contrast: more) {
  :root {
    --color-primary: #0a1a2e;
    --color-text: #000000;
  }
}

